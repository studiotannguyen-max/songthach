# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# Email (Longvan SMTP)
SMTP_HOST=mail.songthach.vn        # host SMTP của Longvan (thường là mail.domain.com)
SMTP_PORT=465                       # 465 = SSL, 587 = STARTTLS
SMTP_SECURE=true                    # true cho port 465, false cho port 587
SMTP_USER=noreply@songthach.vn      # địa chỉ email đầy đủ
SMTP_PASS=your-email-password
SMTP_FROM="Song Thạch <noreply@songthach.vn>"
ADMIN_EMAIL=admin@songthach.vn      # email nhận bản sao thông báo nội bộ

# Admin: danh sách email được cấp quyền admin (phân cách bằng dấu phẩy)
# Khuyến nghị: thêm dòng role='admin' trong bảng users; env này chỉ là bootstrap ban đầu
ADMIN_EMAILS=admin@songthach.com

# Telegram (thông báo đặt sân về chủ)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...   # lấy từ @BotFather
TELEGRAM_CHAT_ID=987654321               # chat ID cá nhân hoặc group
NEXT_PUBLIC_SITE_URL=https://songthach.vn

# VNPay (sandbox)
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payments/callback
