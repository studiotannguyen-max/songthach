# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
ADMIN_EMAIL=admin@songthach.com
RESEND_FROM_EMAIL="Song Thach <noreply@songthach.com>"

# Admin: danh sách email được cấp quyền admin (phân cách bằng dấu phẩy)
# Khuyến nghị: thêm dòng role='admin' trong bảng users; env này chỉ là bootstrap ban đầu
ADMIN_EMAILS=admin@songthach.com

# VNPay (sandbox)
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payments/callback
